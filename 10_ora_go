library(clusterProfiler)
library(DESeq2)
library(org.Hs.eg.db)
library(grid)
library(dplyr)
library(gtable)
library(ggplot2)
library(stringr)

outdir <- "transfer_PRD/thesis"
dir.create(outdir, recursive = TRUE, showWarnings = FALSE)
res <- readRDS("PRD_ONT/outputs/counts/de/res.rds")
res_df <- as.data.frame(res)
res_df$gene <- rownames(res_df)
res_df$gene <- sub("\\..*", "", res_df$gene)
res_df <- res_df %>%
  filter(!is.na(log2FoldChange), !is.na(padj))
  up_genes <- res_df %>%
  filter(padj < 0.05, log2FoldChange > 1) %>%
  pull(gene) %>%
  unique()
down_genes <- res_df %>%
  filter(padj < 0.05, log2FoldChange < -1) %>%
  pull(gene) %>%
  unique()
cat("Number of upregulated genes:", length(up_genes), "\n")
cat("Number of downregulated genes:", length(down_genes), "\n")
up_conv <- bitr(
  up_genes,
  fromType = "ENSEMBL",
  toType = "ENTREZID",
  OrgDb = org.Hs.eg.db
) %>%
  distinct(ENSEMBL, .keep_all = TRUE)
down_conv <- bitr(
  down_genes,
  fromType = "ENSEMBL",
  toType = "ENTREZID",
  OrgDb = org.Hs.eg.db
) %>%
  distinct(ENSEMBL, .keep_all = TRUE)

up_entrez <- unique(up_conv$ENTREZID)
down_entrez <- unique(down_conv$ENTREZID)

cat("Mapped upregulated Entrez IDs:", length(up_entrez), "\n")
cat("Mapped downregulated Entrez IDs:", length(down_entrez), "\n")
ego_up <- enrichGO(
  gene          = up_entrez,
  OrgDb         = org.Hs.eg.db,
  keyType       = "ENTREZID",
  ont           = "BP",
  pAdjustMethod = "BH",
  pvalueCutoff  = 0.05,
  qvalueCutoff  = 0.05,
  readable      = TRUE
)

ego_down <- enrichGO(
  gene          = down_entrez,
  OrgDb         = org.Hs.eg.db,
  keyType       = "ENTREZID",
  ont           = "BP",
  pAdjustMethod = "BH",
  pvalueCutoff  = 0.05,
  qvalueCutoff  = 0.05,
  readable      = TRUE
)
ego_up <- simplify(ego_up, cutoff = 0.7, by = "p.adjust", select_fun = min)
ego_down <- simplify(ego_down, cutoff = 0.7, by = "p.adjust", select_fun = min)

ego_up_df <- as.data.frame(ego_up)
ego_down_df <- as.data.frame(ego_down)

write.csv(
  ego_up_df,
  file = file.path(outdir, "GO_BP_upregulated_full.csv"),
  row.names = FALSE
)

write.csv(
  ego_down_df,
  file = file.path(outdir, "GO_BP_downregulated_full.csv"),
    row.names = FALSE
)

  row.names = FALSE

)
